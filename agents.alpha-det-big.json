{
  "_comment": "大規模 deterministic ロスター: env を α 支配へ寄せた土俵が『多様な戦略』を安定に順位づけられるか(一般性)を安く広くテストする。各 agent は claude-llm.ts を ERIS_FREEZE_STRATEGY=1 で frozen 実行 = baseStrategies.ts の検証済み executor を claude -p なしの決定論で走らせる。uniswap/balancer/curve で動く 9 種(裁定3 + MM/LP4 + 単純2) + baseline。",
  "agents": [
    {
      "id": "f-crossvenue",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "crossvenue",
        "ERIS_FREEZE_STRATEGY": "1"
      },
      "description": "frozen crossvenue: 3-venue delta-neutral 裁定(α)"
    },
    {
      "id": "f-cvbal",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": { "ERIS_BASE_STRATEGY": "cvbal", "ERIS_FREEZE_STRATEGY": "1" },
      "description": "frozen cvbal: balancer↔curve 2-leg 裁定(α)"
    },
    {
      "id": "f-venue",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": { "ERIS_BASE_STRATEGY": "venue", "ERIS_FREEZE_STRATEGY": "1" },
      "description": "frozen venue: 単 venue 乖離丸取り(α・残留β)"
    },
    {
      "id": "f-arb",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": { "ERIS_BASE_STRATEGY": "arb", "ERIS_FREEZE_STRATEGY": "1" },
      "description": "frozen arb: uniswap pool↔fair gap 裁定(単一プール)"
    },
    {
      "id": "f-statarb",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": { "ERIS_BASE_STRATEGY": "statarb", "ERIS_FREEZE_STRATEGY": "1" },
      "description": "frozen statarb: gap z-score 平均回帰"
    },
    {
      "id": "f-fairmm",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": { "ERIS_BASE_STRATEGY": "fairmm", "ERIS_FREEZE_STRATEGY": "1" },
      "description": "frozen fairmm: fair 含意 tick 中心の集中 LP(MM)"
    },
    {
      "id": "f-jitlp",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": { "ERIS_BASE_STRATEGY": "jitlp", "ERIS_FREEZE_STRATEGY": "1" },
      "description": "frozen jitlp: 高ボラ時のみ集中 LP を張る JIT"
    },
    {
      "id": "f-ladder",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": { "ERIS_BASE_STRATEGY": "ladder", "ERIS_FREEZE_STRATEGY": "1" },
      "description": "frozen ladder: 多段集中レンジのラダー型 MM"
    },
    {
      "id": "f-lp",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": { "ERIS_BASE_STRATEGY": "lp", "ERIS_FREEZE_STRATEGY": "1" },
      "description": "frozen lp: 現 tick 周りの素朴な集中 LP"
    },
    {
      "id": "random",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/random.ts"],
      "wallet": "AUTO",
      "baseline": true,
      "description": "baseline（ランダム）"
    },
    {
      "id": "noop",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/noop.ts"],
      "wallet": "AUTO",
      "baseline": true,
      "description": "baseline（何もしない）"
    }
  ]
}
