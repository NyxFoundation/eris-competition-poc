{
  "agents": [
    {
      "id": "ladder-mm",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/ladder-mm.ts"],
      "wallet": "AUTO",
      "description": "Inventory-aware ladder market maker (#7 PR-C). Multi-range LP with skew-driven asymmetric allocation and event-driven rebalance.",
      "env": {
        "LADDER_STEPS": "3",
        "LADDER_INNER_WEIGHT": "0.6",
        "LADDER_OUTER_WEIGHT": "0.4",
        "LADDER_STEP_WIDTH_MULTIPLIER": "20",
        "LADDER_REBALANCE_GAP_BPS": "80",
        "LADDER_REBALANCE_SKEW": "0.3",
        "LADDER_MINT_BUDGET_BPS": "3500"
      }
    },
    {
      "id": "lp-provider",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/lp-provider.ts"],
      "wallet": "AUTO",
      "description": "Baseline single-range LP for side-by-side comparison."
    }
  ]
}
