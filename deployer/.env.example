# anvil RPC エンドポイント (Aave の deploy スクリプトは localhost:8545 固定)
RPC_URL=http://127.0.0.1:8545

# anvil 既定 mnemonic。account index 0 が deployer。
MNEMONIC="test test test test test test test test test test test junk"

# anvil を deployer 自身が起動・終了まで管理する場合 true。
# 既に別ターミナルで `npm run anvil` を起動済みなら false。
MANAGE_ANVIL=true
