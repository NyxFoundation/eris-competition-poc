diff --git a/utils/setBalanceCompat.ts b/utils/setBalanceCompat.ts
new file mode 100644
index 0000000..ec10fe7
--- /dev/null
+++ b/utils/setBalanceCompat.ts
@@ -0,0 +1,11 @@
+// anvil 互換の setBalance。
+// @nomicfoundation/hardhat-network-helpers の setBalance は接続先が
+// Hardhat Network でないと拒否するため、anvil でも使える生 RPC
+// (hardhat_setBalance / anvil_setBalance のエイリアス) を直接叩く。
+import { network } from "hardhat";
+import { BigNumberish } from "ethers";
+import { hexValue } from "ethers/lib/utils";
+
+export async function setBalance(address: string, value: BigNumberish) {
+  await network.provider.send("hardhat_setBalance", [address, hexValue(value)]);
+}
