{
  "_comment": "自己改善エージェントの競争に『実力に基づく優劣（識別力）』がつくかを discrimination(C1/C2/C3) で測るロスター。実力軸=自己改善の質。期待勾配: {frozen-good, si-cli-good} > si-cli-weak > {si-mock≈noop, random} > noop。claude -p を使うのは si-cli-good / si-cli-weak の 2 体のみ（並行 2）。",
  "agents": [
    {
      "id": "si-cli-good",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "crossvenue",
        "ERIS_LLM_AUTH": "cli",
        "ERIS_LLM_REVIEW_EVERY": "60"
      },
      "description": "real 自己改善・良い出発点（crossvenue + cli LLM）"
    },
    {
      "id": "si-cli-weak",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "arb",
        "ERIS_LLM_AUTH": "cli",
        "ERIS_LLM_REVIEW_EVERY": "60"
      },
      "description": "real 自己改善・弱い出発点（単一プール arb + cli LLM）"
    },
    {
      "id": "si-mock",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "crossvenue",
        "ERIS_LLM_AUTH": "mock",
        "ERIS_LLM_REVIEW_EVERY": "60"
      },
      "description": "破滅的自己改善（良い base を mock revise が noop へ改悪）= floor アンカー"
    },
    {
      "id": "frozen-good",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "crossvenue",
        "ERIS_FREEZE_STRATEGY": "1"
      },
      "description": "自己改善なし・良い base 固定（ceiling アンカー）"
    },
    {
      "id": "random",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/random.ts"],
      "wallet": "AUTO",
      "baseline": true,
      "description": "baseline（ランダム）"
    },
    {
      "id": "noop",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/noop.ts"],
      "wallet": "AUTO",
      "baseline": true,
      "description": "baseline（何もしない・benchmark）"
    }
  ]
}
