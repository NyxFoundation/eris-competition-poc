{
  "agents": [
    {
      "id": "arb",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/arb-bot.ts"],
      "wallet": "AGENT0_PRIVATE_KEY",
      "env": { "BID_PROFIT_FRACTION": "0.3" },
      "description": "Uniswap gap 駆動 arb（priority fee 入札）"
    },
    {
      "id": "gmx-rev",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/gmx-reversion.ts"],
      "wallet": "AGENT1_PRIVATE_KEY",
      "env": {
        "MA_LOOKBACK": "12",
        "ENTRY_BPS": "40",
        "EXIT_BPS": "10",
        "STOP_USD": "150"
      },
      "description": "GMX perp 平均回帰（MA 乖離で逆張り）"
    },
    {
      "id": "cvbal",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/cv-bal-arb.ts"],
      "wallet": "AGENT2_PRIVATE_KEY",
      "env": { "SPREAD_BPS": "15" },
      "description": "Balancer/Curve スプレッド ペア裁定（bundle）"
    },
    {
      "id": "dn-lp",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/dn-lp.ts"],
      "wallet": "AGENT3_PRIVATE_KEY",
      "env": { "HEDGE_FRACTION": "1.0" },
      "description": "Uniswap LP + GMX short のデルタニュートラル"
    },
    {
      "id": "noop",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/noop.ts"],
      "wallet": "AGENT4_PRIVATE_KEY",
      "baseline": true,
      "description": "ベースライン: 何もしない（識別力の下限物差し）"
    },
    {
      "id": "random",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/random.ts"],
      "wallet": "AGENT5_PRIVATE_KEY",
      "baseline": true,
      "description": "ベースライン: でたらめ売買（決定論シード）"
    }
  ]
}
