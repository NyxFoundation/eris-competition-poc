{
  "_comment": "打ち手2: β 同質(cross-venue 系)の強い自己改善器だけで discrimination PASS を実証するロスター。実力勾配 = base の質: crossvenue(3-venue 両建て=最強) > cvbal(2-venue 両建て=中) > venue(単一 venue・maxSize2500=弱)。全て cli LLM 自己改善。baseline=random/noop。opportunity-rich regime(3,4)で評価(regime2 は全員 noop 負けの無機会局面で C2 を壊すため除外)。",
  "agents": [
    {
      "id": "si-cv",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "crossvenue",
        "ERIS_LLM_AUTH": "cli",
        "ERIS_LLM_REVIEW_EVERY": "60"
      },
      "description": "強: 3-venue 両建て裁定 + cli LLM 自己改善"
    },
    {
      "id": "si-cvbal",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "cvbal",
        "ERIS_LLM_AUTH": "cli",
        "ERIS_LLM_REVIEW_EVERY": "60"
      },
      "description": "中: 2-venue(balancer/curve)両建て裁定 + cli LLM 自己改善"
    },
    {
      "id": "si-venue",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "venue",
        "ERIS_LLM_AUTH": "cli",
        "ERIS_LLM_REVIEW_EVERY": "60"
      },
      "description": "弱: 単一 venue 寄せ(maxSize 2500) + cli LLM 自己改善"
    },
    {
      "id": "random",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/random.ts"],
      "wallet": "AUTO",
      "baseline": true,
      "description": "baseline（ランダム）"
    },
    {
      "id": "noop",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/noop.ts"],
      "wallet": "AUTO",
      "baseline": true,
      "description": "baseline（何もしない・benchmark）"
    }
  ]
}
